{
  "name": "life-desktop",
  "private": true,
  "version": "1.0.2",
  "description": "A local-first personal workspace for tasks, notes, books, videos, credentials, and backups.",
  "author": "Shawn",
  "main": "dist-electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=24.18.0 <25"
  },
  "scripts": {
    "dev": "node scripts/run-with-electron-env.mjs vite",
    "rebuild:native": "electron-builder install-app-deps && npm run verify:native",
    "verify:native": "node scripts/verify-native-module.mjs",
    "verify:package:win": "node scripts/verify-windows-package.mjs",
    "postinstall": "npm run rebuild:native",
    "test": "node scripts/run-tests.mjs",
    "build": "tsc -b && vite build",
    "build:app": "npm run build && npm run verify:native && electron-builder",
    "lint": "eslint .",
    "format": "prettier --write .",
    "preview": "vite preview"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "adm-zip": "^0.6.0",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.12",
    "electron-updater": "^6.8.9",
    "gsap": "^3.15.0",
    "i18next": "^26.3.6",
    "lucide-react": "^1.26.0",
    "marked": "^18.0.7",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.8",
    "react-dom": "^19.2.8",
    "react-i18next": "^17.0.11",
    "react-pdf": "^10.4.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/better-sqlite3": "^7.6.13",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^24.13.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.4",
    "electron": "^42.6.1",
    "electron-builder": "^26.15.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.5",
    "vite-plugin-electron": "^1.1.0",
    "vite-plugin-electron-renderer": "^1.0.0"
  },
  "build": {
    "appId": "com.wdzwatson.lifedesktop",
    "productName": "LifeOS",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "win": {
      "target": [
        "nsis",
        "zip"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "wdzwatson",
        "repo": "life-desktop"
      }
    ]
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron-winstaller@5.4.0": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
